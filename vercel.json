{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/tv", "dest": "/tv/index.html" },
    { "src": "/tv/(.*)", "dest": "/tv/index.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
