{
  "rewrites": [
    { "source": "/acheiproducao", "destination": "/acheiproducao/index.html" },
    { "source": "/oceanmarine",   "destination": "/oceanmarine/index.html"   },
    { "source": "/demos",         "destination": "/demos/index.html"         }
  ],
  "headers": [
    {
      "source": "/(acheiproducao|oceanmarine|demos)/(.*)",
      "headers": [{ "key": "X-Frame-Options", "value": "SAMEORIGIN" }]
    }
  ]
}
