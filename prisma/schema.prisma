generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  credits       Int        @default(50)   // créditos = segundos de vídeo
  plan          String     @default("free") // free | basico | premium | avancado
  planExpiresAt DateTime?
  lang          String     @default("pt")
  role          String     @default("user") // user | admin
  accounts      Account[]
  creations     Creation[]
  payments      Payment[]
  sessions      Session[]
  createdAt     DateTime   @default(now())
}

model Creation {
  id          String   @id @default(cuid())
  userId      String
  prompt      String
  model       String   @default("seedance2") // seedance2 | kling3 | veo3 | flux | etc
  provider    String   @default("byteplus")  // byteplus | atlascloud | muapi | replicate
  aspectRatio String?
  resolution  String?
  duration    Int?     // segundos
  quality     String?
  mode        String   @default("text-to-video") // text-to-video | image-to-video | reference-to-video
  status      String   @default("processing")    // processing | completed | failed
  requestId   String?  @unique
  imageUrl    String?  // URL do vídeo ou imagem gerada
  thumbnailUrl String? // Thumbnail (primeiro frame)
  error       String?
  creditsUsed Int      @default(0)
  audioFiles  String[]
  videoFiles  String[]
  inputImages String[]
  group       String   @default("Geral")    // agrupamento por projeto
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  provider   String   // stripe | mercadopago | paypal
  externalId String?  // ID na plataforma de pagamento
  plan       String   // basico | premium | avancado
  amount     Float    // em BRL
  credits    Int      // créditos concedidos
  status     String   @default("pending") // pending | paid | failed | refunded
  metadata   Json?
  createdAt  DateTime @default(now())
  paidAt     DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
