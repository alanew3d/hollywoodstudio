# HOLLYWOOD STUDIO AI — Variáveis de Ambiente
# Copie para .env.local e preencha com seus valores

# App
NEXTAUTH_URL="https://hollywoodstudio.ai"
NEXTAUTH_SECRET="gere com: openssl rand -base64 32"
WEBHOOK_URL="https://hollywoodstudio.ai"
NEXT_PUBLIC_SITE_NAME="Hollywood Studio AI"
NEXT_PUBLIC_THEME="gold"

# Banco (Neon.tech free tier — console.neon.tech)
DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/neondb?sslmode=require"

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# BytePlus ModelArk — Seedance 2.0 PRINCIPAL (ark.byteplus.com)
BYTEPLUS_API_KEY="sua_chave_byteplus"
BYTEPLUS_BASE_URL="https://ark.ap-southeast.bytepluses.com"

# Atlas Cloud — multi-modelo
ATLASCLOUD_API_KEY="sua_chave_atlascloud"
ATLASCLOUD_BASE_URL="https://api.atlascloud.ai"

# muapi.ai — compatibilidade boilerplate (USE_MUAPI=false para BytePlus)
USE_MUAPI="false"
SEEDANCE_V2_API_KEY="sua_chave_muapi_ou_byteplus"

# Replicate — fallback
REPLICATE_API_TOKEN="r8_xxx"

# Stripe (dashboard.stripe.com > Developers > API Keys)
STRIPE_SECRET_KEY="sk_live_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Stripe Payment Links (stripe.com/payment-links — crie 1 por plano)
NEXT_PUBLIC_STRIPE_LINK_BASICO="https://buy.stripe.com/xxx"
NEXT_PUBLIC_STRIPE_LINK_PREMIUM="https://buy.stripe.com/xxx"
NEXT_PUBLIC_STRIPE_LINK_AVANCADO="https://buy.stripe.com/xxx"

# MercadoPago — Pix, Boleto, Cartao BR (mercadopago.com.br > Credenciais)
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxx"
MERCADOPAGO_WEBHOOK_SECRET="seu_webhook_secret"

# PayPal (email apenas, para paypal.me simples)
NEXT_PUBLIC_PAYPAL_EMAIL="alansorrah@gmail.com"

# Cloudflare R2 — uploads de referencia (dash.cloudflare.com > R2)
R2_ACCOUNT_ID="seu_account_id"
R2_ACCESS_KEY_ID="sua_access_key"
R2_SECRET_ACCESS_KEY="seu_secret"
R2_BUCKET_NAME="hollywoodstudio"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"
