# ============================================================
# Hollywood Studio AI — Variáveis de Ambiente
# NUNCA commitar o arquivo .env real.
# Cole estas variáveis em: Vercel Dashboard > Settings > Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs dos planos (criar no Stripe Dashboard > Products)
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=
# Links diretos de checkout (opcional — alternativa aos Price IDs)
STRIPE_LINK_CREATOR=
STRIPE_LINK_PRO=
STRIPE_LINK_STUDIO=
# Créditos avulsos (top-ups)
STRIPE_PRICE_T100=
STRIPE_PRICE_T300=
STRIPE_PRICE_T700=

# ── Resend (e-mails transacionais) ───────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@hollywoodstudio.ai

# ── IA ───────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Google Auth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Provedores de geração ────────────────────────────────────
ATLAS_BASE=https://api.atlascloud.ai
ATLAS_KEY=
FAL_KEY=
MODELARK_KEY=

# ── Creative Finisher / Finishing Lab ────────────────────────
# Magnific (upscale premium, inpainting, relight, style transfer, expand, remove bg)
MAGNIFIC_API_KEY=
# Atlas Cloud para ferramentas do Finisher (change camera, lip sync)
ATLAS_API_KEY=

# ── App ──────────────────────────────────────────────────────
APP_URL=https://hollywoodstudio.ai
ADMIN_EMAILS=seu@email.com

# ── Vercel KV (Upstash Redis — legado, opcional) ─────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Feature Flags ────────────────────────────────────────────
# Defina 'false' para desativar um recurso
FLAG_TRIAL=true
FLAG_PAYMENTS=true
FLAG_UPLOADS=true
FLAG_AI_TEXT=true
FLAG_VIDEO_GEN=true
FLAG_PUBLIC_GALLERY=true
FLAG_INSTAGRAM=true
FLAG_FOUNDER_OFFER=true

# ── Créditos ─────────────────────────────────────────────────
# FREE_CREDITS: concedidos a novos usuários pelo trigger do Supabase (não usar aqui)
TRIAL_CREDITS=3

# ── CORS (domínios extras separados por vírgula) ──────────────
CORS_ORIGINS=
