# Hollywood Studio AI — Fase 1
DATABASE_URL="postgresql://user:password@host:port/dbname"
DIRECT_URL="postgresql://user:password@host:port/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret"

# Google Auth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Video provider — Phase 1 keeps original Seedance/muapi-compatible API
AI_PROVIDER="muapi"
SEEDANCE_V2_API_KEY="your_seedance_api_key"
WEBHOOK_URL="https://your-vercel-domain.vercel.app"

# Optional future providers
BYTEPLUS_API_KEY=""
BYTEPLUS_BASE_URL="https://ark.ap-southeast.bytepluses.com/api/v3"
ATLASCLOUD_API_KEY=""
ATLASCLOUD_BASE_URL="https://api.atlascloud.ai"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# UI
NEXT_PUBLIC_THEME=hollywood
DEFAULT_FREE_CREDITS=10
