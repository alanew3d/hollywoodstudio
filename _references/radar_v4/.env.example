# ═══════════════════════════════════════════
# diretor.ai — Variáveis de Ambiente
# Copie para .env.local para desenvolvimento
# No Vercel: Settings → Environment Variables
# ═══════════════════════════════════════════

# Anthropic Claude API
# Obter em: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-SUACHAVEAQUI

# Supabase
# Obter em: app.supabase.com → Settings → API
SUPABASE_URL=https://SEUPROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...  # service_role key (NÃO a anon key)

# Chave pública do Supabase (vai no HTML — pode ser pública)
NEXT_PUBLIC_SUPABASE_URL=https://SEUPROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...  # anon/public key

# Stripe
# Obter em: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_SUACHAVE
STRIPE_WEBHOOK_SECRET=whsec_SEUCRETWEBHOOK  # criado ao configurar webhook

# Mercado Pago
# Obter em: mercadopago.com.br/developers → Credenciais
MP_ACCESS_TOKEN=APP_USR-SUACHAVE

# Email (Resend)
# Obter em: resend.com → API Keys
RESEND_API_KEY=re_SUACHAVE

# Admin
# Email da conta que terá acesso ao painel admin
ADMIN_EMAIL=seu@email.com
